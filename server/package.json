{
  "name": "inventrack-server",
  "version": "1.0.0",
  "description": "Backend API for InvenTrack Inventory Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seeders/seed.js",
    "test": "vitest run --reporter verbose --globals",
    "profile:doctor": "node profiler_runner.js doctor /api/health 10 5",
    "profile:flame": "node profiler_runner.js flame /api/health 10 5",
    "profile:bubble": "node profiler_runner.js bubbleprof /api/health 10 3",
    "profile:all": "node profiler_runner.js all /api/health 10 5",
    "profile:items": "node profiler_runner.js doctor /api/items 15 10",
    "profile:clean": "npx rimraf .clinic && echo Clinic results cleaned!"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "clinic": "^13.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
